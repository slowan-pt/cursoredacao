{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "cursoreducao",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-20",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "workers_dev": true,
  "vars": {
    "APP_ENV": "production",
    "APP_URL": "https://redacaocomestrategia.com.br",
    "APP_VERSION": "1.0.0",
    "ENABLE_PAYMENTS": "true",
    "ASAAS_ENV": "sandbox",
    "ENABLE_R2_UPLOADS": "true",
    "ENABLE_EMAILS": "false",
    "ENABLE_OAUTH": "false",
    "ENABLE_PUBLIC_CHECKOUT_SIMULATED": "false",
    "ENABLE_APP_RATE_LIMITING": "false",
    "MAX_UPLOAD_BYTES": "8388608"
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": ["/health", "/api/*", "/s/*"]
  },
  "r2_buckets": [
    {
      "binding": "R2_UPLOADS",
      "bucket_name": "redacao-uploads"
    }
  ]
}
