{
  "name": "cursoredacao",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "typecheck:unused": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "check:diff": "git diff --check",
    "check:public": "node scripts/check-public-metadata.mjs",
    "audit:static": "node scripts/audit-static.mjs",
    "check:financial": "node scripts/check-financial-module.mjs",
    "financial:smoke": "node scripts/financial-transaction-smoke.mjs",
    "financial:backfill:dry-run": "node scripts/financial-backfill-dry-run.mjs",
    "preview:emails": "node scripts/preview-emails.mjs",
    "smoke:prod": "node scripts/production-smoke.mjs",
    "check:all": "npm run typecheck && npm run typecheck:unused && npm run security:scan && npm run check:public && npm run audit:static && npm run check:financial && npm run check:diff",
    "setup": "node scripts/setup.mjs",
    "security:scan": "node scripts/scan-secrets.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "hono": "^4.6.20"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "pg": "^8.22.0",
    "typescript": "^5.5.4",
    "wrangler": "^4.98.0"
  }
}
